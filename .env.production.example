# ─────────────────────────────────────────────────────────────────────────────
# DISC Report — PRODUCTION .env template
#
# Copy this to .env on the production host. R-08 requires:
#   - APP_DEBUG=false  (no stack traces visible to users)
#   - LOG_CHANNEL=daily (rotated log files; no unbounded growth)
#   - LOG_LEVEL>=warning (info logs are noise in prod)
#
# Branded error pages (404/403/419/429/500/503) live in
# resources/views/errors/ and are picked up automatically.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="DISC Report"
APP_ENV=production
APP_KEY=                              # run: php artisan key:generate --force
APP_DEBUG=false
APP_URL=https://discreport.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily                     # rotates one file per day
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30                     # keep 30 days of rotated logs

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ── Session / cache / queue ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true                  # encrypt session payloads at rest
SESSION_SECURE_COOKIE=true            # HTTPS-only cookies
SESSION_DOMAIN=.discreport.com

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Mail (R-26): SendGrid / Mailgun / Postmark / SES ────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@discreport.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Stripe (R-34) ────────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── SSO (R-30; optional until UI buttons ship) ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Twilio SMS (R-31; optional until UI ships) ──────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── Trust proxy (when fronted by Cloudflare / load balancer) ────────────────
TRUSTED_PROXIES=*
